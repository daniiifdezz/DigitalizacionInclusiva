<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Nivel INFO para el servidor en general -->
    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>

    <!-- Nivel DEBUG solo para nuestro código -->
    <logger name="org.dferna14.project.backend" level="DEBUG"/>
</configuration>